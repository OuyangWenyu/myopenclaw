# =============================================================
# openclaw 环境变量模板 — 敏感 Key 放 .secrets/openclaw.env
# =============================================================

OPENCLAW_PORT=3000
OPENCLAW_LOG_LEVEL=info

# 数据目录（容器内路径，对应 docker-compose volumes）
OPENCLAW_DATA_DIR=/data

# 示例：非敏感配置
# OPENCLAW_MODEL=gpt-4o
# OPENCLAW_LANGUAGE=zh-CN
