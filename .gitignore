# ── Secrets & 环境变量（真实值） ────────────────────────────────
.env
.env.local
# .secrets/ 目录由 git-crypt 加密，.gitattributes 中已声明

# ── 云盘配置（本机路径，不入 git） ──────────────────────────────
.cloud.conf

# ── 运行时数据（在宿主机 ~/.hermes 和 ~/.openclaw，不在本仓库）──

# ── macOS ────────────────────────────────────────────────────────
.DS_Store

# ── 允许提交的模板文件（显式覆盖上面的忽略规则） ─────────────────
!.env.example
!*/.env.example
!.cloud.conf.example