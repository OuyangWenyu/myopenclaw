# ── Secrets & 环境变量（真实值） ────────────────────────────────
.env
.env.local
# .secrets/ 目录由 git-crypt 加密，.gitattributes 中已声明

# ── 云盘配置（本机路径，不入 git） ──────────────────────────────
.cloud.conf

# ── 运行时数据（数据库、日志、缓存）→ 云盘软链接，不入 git ─────
.data
*.db
*.log

# ── macOS ────────────────────────────────────────────────────────
.DS_Store

# ── 允许提交的模板文件（显式覆盖上面的忽略规则） ─────────────────
!.env.example
!*/.env.example
!.cloud.conf.example