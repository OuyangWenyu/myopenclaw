# =============================================================
# 全局环境变量模板 — 复制为 .env 并填写真实值
# =============================================================

# ── 通用 ─────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── LLM API Keys（Hermes + OpenClaw 共用）─────────────────────
# DeepSeek — 两服务默认模型 deepseek-v4-flash
DEEPSEEK_API_KEY=sk-...
# Moonshot — OpenClaw 备份模型 kimi-k2.5，Hermes opencode 可选
# MOONSHOT_API_KEY=sk-...
# 智谱 GLM — Claude Code 的 ANTHROPIC_API_KEY，Hermes opencode 默认模型
# GLM_API_KEY=xxxxx.xxxxx
# 若需使用真实 Anthropic API 而非智谱，取消下行注释并清空 GLM_API_KEY
# ANTHROPIC_API_KEY=sk-ant-...
# opencode 专用 Key（不填则走默认 GLM）
# OPENCODE_API_KEY=xxxxx
# OpenRouter（Hermes opencode 可选）
# OPENROUTER_API_KEY=xxxxx
# OpenAI（Hermes opencode 可选）
# OPENAI_API_KEY=sk-...

# ── Hermes ───────────────────────────────────────────────────
HERMES_PORT=8642
HERMES_CODER_PORT=8643
HERMES_FINANCE_PORT=8644
HERMES_DASHBOARD_PORT=9119
# GitHub CLI token（容器内以 GITHUB_TOKEN 传递，绕过 Hermes 黑名单）
# GH_TOKEN=github_pat_xxxx
# Finance agent 飞书应用（独立于主 Hermes 的飞书 app）
# FINANCE_FEISHU_APP_ID=cli_xxxx
# FINANCE_FEISHU_APP_SECRET=xxxxx
# 注：DEEPSEEK/OPENROUTER/OPENAI 密钥被 Hermes 安全黑名单拦截，
# entrypoint 会自动将其写入 /opt/data/secrets/ 文件，opencode.json 用 {file:} 引用

# ── OpenClaw ─────────────────────────────────────────────────
OPENCLAW_PORT=18789
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest   # 使用预构建镜像
# GitHub token（团队账号，用于 OpenClaw MCP server 创建/管理 issue）
# OPENCLAW_GH_TOKEN=ghp_xxxx

# ── paper-fetch skill（公开论文 PDF 下载器）────────────────────
# 设置 Unpaywall 联系邮箱可提高 OA 命中率（可选）
# UNPAYWALL_EMAIL=you@example.com
# 关闭 Sci-Hub 兜底（默认开启，作为最后回退源）
# PAPER_FETCH_NO_SCIHUB=1

# ── 备份（backup-cron 容器）─────────────────────────────────
# cron 表达式：默认每周日凌晨 2:00 备份一次
BACKUP_CRON=0 2 * * 0
# 快照保留天数（超过后自动删除旧快照）
BACKUP_KEEP_DAYS=30
# BACKUP_ROOT 由 docker-compose 从 .cloud.conf 解析后注入，无需手动填写
