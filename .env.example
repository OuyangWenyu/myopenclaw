# =============================================================
# 全局环境变量模板 — 复制为 .env 并填写真实值
# =============================================================

# ── 通用 ─────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── hermes ───────────────────────────────────────────────────
HERMES_PORT=8642
HERMES_DASHBOARD_PORT=9119
# GitHub CLI token（容器内以 GITHUB_TOKEN 传递，绕过 Hermes 黑名单）
# GH_TOKEN=github_pat_xxxx
# opencode LLM 密钥（也可写入 ~/.hermes/secrets/ 文件，见下方说明）
# OPENCODE_API_KEY=xxxxx
# GLM_API_KEY=xxxxx.xxxxx
# ANTHROPIC_API_KEY=sk-ant-...
# 以下密钥被 Hermes 安全黑名单拦截，不通过环境变量传递，
# 请写入 ~/.hermes/secrets/ 下的对应文件（容器内路径 /opt/data/secrets/）：
#   openrouter-api-key  →  {file:/opt/data/secrets/openrouter-api-key}
#   deepseek-api-key    →  {file:/opt/data/secrets/deepseek-api-key}
#   openai-api-key      →  {file:/opt/data/secrets/openai-api-key}

# ── openclaw ─────────────────────────────────────────────────
OPENCLAW_PORT=18789
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest   # 使用预构建镜像

# ── 备份（backup-cron 容器）─────────────────────────────────
# cron 表达式：默认每周日凌晨 2:00 备份一次
BACKUP_CRON=0 2 * * 0
# 快照保留天数（超过后自动删除旧快照）
BACKUP_KEEP_DAYS=30
# BACKUP_ROOT 由 docker-compose 从 .cloud.conf 解析后注入，无需手动填写
