# =============================================================
# 全局环境变量模板 — 复制为 .env 并填写真实值
# =============================================================

# ── 通用 ─────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── LLM API Keys（Hermes + OpenClaw + Claude Code 共用）─────────
# DeepSeek — 两服务默认模型 deepseek-v4-flash
DEEPSEEK_API_KEY=sk-...
# Moonshot — OpenClaw 备份模型 kimi-k2.5，Hermes opencode 可选
# MOONSHOT_API_KEY=sk-...
# OpenRouter（Hermes opencode 可选）
# OPENROUTER_API_KEY=xxxxx
# OpenAI（Hermes opencode 可选）
# OPENAI_API_KEY=sk-...

# ── Hermes ───────────────────────────────────────────────────
HERMES_PORT=8642
HERMES_CODER_PORT=8643
HERMES_FINANCE_PORT=8644
HERMES_DASHBOARD_PORT=9119
# GitHub CLI token（容器内以 GITHUB_TOKEN 传递，绕过 Hermes 黑名单）
# GH_TOKEN=github_pat_xxxx
# Gitcode personal access token（容器内以 GITCODE_TOKEN 传递，claude-code 访问 gitcode.com 私有仓库）
# GITCODE_TOKEN=xxxxx
# Finance agent 飞书应用（独立于主 Hermes 的飞书 app）
# FINANCE_FEISHU_APP_ID=cli_xxxx
# FINANCE_FEISHU_APP_SECRET=xxxxx
# Hermes 飞书主动推送凭证（所有定时推送共用 Hermes 身份）
# 使用场景: Morning Triage v2 每日汇总 + AI News 周报推送 + 未来主动通知
# 不填则 fallback 到 LARK_CLI_APP_ID/SECRET（Hermes 飞书 bot 同一组凭证）
# FEISHU_APP_ID=cli_xxxx
# FEISHU_APP_SECRET=xxxxx
# lark-cli 飞书应用凭证（不填则自动绑定 Hermes 内置飞书应用）
# LARK_CLI_APP_ID=cli_xxxx
# LARK_CLI_APP_SECRET=xxxxx
# 爱码士应用（第二个 profile，可选）
# LARK_CLI_IDM_APP_ID=cli_xxxx
# LARK_CLI_IDM_APP_SECRET=xxxxx
# Discord Bot（爱码士 — Hermes Discord 接入，可选）
# DISCORD_BOT_TOKEN=xxxxx
# DISCORD_ALLOWED_USERS=你的Discord用户ID
# ── Zotero CLI（zotero-cli-cc — 文献管理命令行工具）────────────
# 读取无需 API key（SQLite 直读）。创建/修改条目需要 Web API key。
# 在 https://www.zotero.org/settings/keys 创建 key（勾选 Allow library access）
# ZOTERO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# ZOTERO_LIBRARY_ID=1234567          # https://www.zotero.org/settings/keys 可查
# ZOTERO_LIBRARY_TYPE=user
# 注：DEEPSEEK/OPENROUTER/OPENAI 密钥被 Hermes 安全黑名单拦截，
# entrypoint 会自动将其写入 /opt/data/secrets/ 文件，opencode.json 用 {file:} 引用

# ── Google Drive Papers 本地路径（paper-to-zotero 工作流用）─────
# Google Drive 客户端本地同步路径下的 Papers 子目录
# GDRIVE_PAPERS_LOCAL_PATH=~/Google Drive/我的云端硬盘/Papers/Zotero_Papers

# ── Claude Code + cc-connect ────────────────────────────────
# 智谱 GLM — Claude Code 的 ANTHROPIC_API_KEY
# GLM_API_KEY=xxxxx.xxxxx
# 若需使用真实 Anthropic API 而非智谱，取消下行注释并清空 GLM_API_KEY
# ANTHROPIC_API_KEY=sk-ant-...
# cc-connect 飞书应用凭证（独立于 Hermes 的飞书 bot）
# CC_CONNECT_FEISHU_APP_ID=cli_xxxx
# CC_CONNECT_FEISHU_APP_SECRET=xxxxx
CC_CONNECT_PORT=9090
# opencode 专用 Key（不填则走默认 GLM）
# OPENCODE_API_KEY=xxxxx

# ── OpenClaw ─────────────────────────────────────────────────
OPENCLAW_PORT=18789
# Docker 镜像版本（固定版本号避免意外升级导致配置格式不兼容）
# launchd 网关 (npm global) 和 Docker 网关必须保持相同版本
# 升级时需同步更新此处和 npm global: npm install -g openclaw@<版本>
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.15
# GitHub token（团队账号，用于 OpenClaw MCP server 创建/管理 issue）
# OPENCLAW_GH_TOKEN=ghp_xxxx

# ── paper-fetch skill（公开论文 PDF 下载器）────────────────────
# 设置 Unpaywall 联系邮箱可提高 OA 命中率（可选）
# UNPAYWALL_EMAIL=you@example.com
# 关闭 Sci-Hub 兜底（默认开启，作为最后回退源）
# PAPER_FETCH_NO_SCIHUB=1

# ── Uptime Kuma（服务监控面板）───────────────────────────────
UPTIME_KUMA_PORT=3001
# 管理员账号密码（setup-uptime-kuma-monitors.py 自动读取，无需手动输入）
UPK_USER=owen
UPK_PASS=your_password_here

# ── TDAI Memory Gateway（Agent 长期记忆 L0→L3 分层管线）─────────
TDAI_MEMORY_PORT=8420
# LLM 后端（L1→L3 抽取用，默认复用 DeepSeek）
# TDAI_LLM_BASE_URL=https://api.deepseek.com/v1
# TDAI_LLM_MODEL=deepseek-chat

# ── Healthchecks.io（死信开关 — 整机/Docker 全崩时独立告警）───
# 在 https://healthchecks.io 创建 Check，将 Ping URL 填到这里
# 格式: https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid-here

# ── 备份（backup-cron 容器）─────────────────────────────────
# cron 表达式：默认每周日凌晨 2:00 备份一次
BACKUP_CRON=0 2 * * 0
# 快照保留天数（超过后自动删除旧快照）
BACKUP_KEEP_DAYS=30
# BACKUP_ROOT 由 docker-compose 从 .cloud.conf 解析后注入，无需手动填写
