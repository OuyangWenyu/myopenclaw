# =============================================================
# 全局环境变量模板 — 复制为 .env 并填写真实值
# 敏感 API Key 请放入 .secrets/openclaw.env 和 .secrets/hermes.env
# =============================================================

# ── 通用 ─────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── openclaw ─────────────────────────────────────────────────
OPENCLAW_PORT=4300
# OPENCLAW_LOG_LEVEL=info

# ── hermes ───────────────────────────────────────────────────
HERMES_PORT=4301
# HERMES_LOG_LEVEL=info
