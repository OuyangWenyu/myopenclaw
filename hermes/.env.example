# =============================================================
# hermes 环境变量模板 — 敏感 Key 放 .secrets/hermes.env
# =============================================================

HERMES_PORT=3001
HERMES_LOG_LEVEL=info

# 数据目录（容器内路径，对应 docker-compose volumes）
HERMES_DATA_DIR=/data

# 示例：非敏感配置
# HERMES_MODEL=gpt-4o
